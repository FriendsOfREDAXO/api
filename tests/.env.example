## Copy this file to tests/.env and fill in your local values.
## tests/.env is gitignored.

API_TEST_BASE_URL=https://redaxo.localhost
API_TEST_API_PREFIX=/api
API_TEST_VERIFY_SSL=0
API_TEST_TIMEOUT=30
API_TEST_DEBUG=1

# Bearer token: create one in Backend → API → Token,
# grant it ALL scopes the test suite hits.
API_TEST_TOKEN=

# Backend-User credentials. The admin must exist; the restricted user
# can be created with:
#   bin/console user:create apitest_restricted <password> --name="API Test Restricted"
API_TEST_ADMIN_LOGIN=admin
API_TEST_ADMIN_PASSWORD=
API_TEST_RESTRICTED_LOGIN=apitest_restricted
API_TEST_RESTRICTED_PASSWORD=

# Existing IDs (must exist in the DB).
API_TEST_EXISTING_ARTICLE_ID=1
API_TEST_EXISTING_CATEGORY_ID=1
API_TEST_EXISTING_CLANG_ID=1
API_TEST_EXISTING_TEMPLATE_ID=1
API_TEST_EXISTING_MODULE_ID=1
